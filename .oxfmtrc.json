{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "trailingComma": "all",
  "semi": true,
  "tabWidth": 2,
  "printWidth": 100,
  "importOrder": [
    "<THIRD_PARTY_TS_TYPES>",
    "^[./]"
  ],
  "importOrderSeparation": false,
  "importOrderSortSpecifiers": true,
  "importOrderParserPlugins": [
    "typescript"
  ],
  "sortPackageJson": false,
  "ignorePatterns": [
    ".github/",
    "dist/",
    "docs/",
    "node_modules/",
    "protocol/",
    "src/proto/",
    "src/room/attributes/",
    "yarn.lock",
    "pnpm-lock.yaml"
  ]
}
